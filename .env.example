# Auth
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # En prod: https://jp.com.ar

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Home Assistant (servidor casero)
HA_URL=                   # ej: https://ha.jp.com.ar
HA_TOKEN=                 # Long-lived access token de HA

# Vercel KV (se genera automático al conectar KV en Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# URL del servidor (para health checks internos)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
